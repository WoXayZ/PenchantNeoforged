# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicitly treat these as text
*.java   text eol=lf
*.json   text eol=lf
*.toml   text eol=lf
*.gradle text eol=lf
*.md     text eol=lf
*.mcmeta text eol=lf
*.properties text eol=lf

# Windows-only wrapper script keeps CRLF
*.bat    text eol=crlf

# Binary assets
*.png    binary
*.jar    binary
